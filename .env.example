# ===========================================
# Acreed Consulting — Docker Environment
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# JWT Secret — generate a strong random string (32+ chars)
# Example: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Initial admin account (created on first startup via db:seed)
ADMIN_EMAIL=admin@acreedconsulting.com
ADMIN_PASSWORD=your-strong-password-here
ADMIN_NAME=Admin Acreed

# CORS — set to your production domain (with https://)
CORS_ORIGIN=https://yourdomain.com
